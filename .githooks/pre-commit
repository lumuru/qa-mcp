#!/usr/bin/env bash
# Pre-commit hook: block staged content that matches patterns defined in
# .githooks/patterns.local (not tracked in git). See .githooks/patterns.example
# for the expected file format.
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# If .githooks/patterns.local does not exist, content scanning is skipped
# silently (the hook does not block the commit).

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
PATTERN_FILE="${REPO_ROOT}/.githooks/patterns.local"

if [[ ! -f "${PATTERN_FILE}" ]]; then
  exit 0
fi

# Load patterns: strip blank lines and comments.
PATTERNS=()
while IFS= read -r line || [[ -n "${line}" ]]; do
  [[ -z "${line}" || "${line}" =~ ^[[:space:]]*# ]] && continue
  PATTERNS+=("${line}")
done < "${PATTERN_FILE}"

if [[ ${#PATTERNS[@]} -eq 0 ]]; then
  exit 0
fi

JOINED=$(IFS='|'; echo "${PATTERNS[*]}")

# Files exempt from scanning — patterns.local itself legitimately contains
# the strings we're guarding against.
EXCLUDE_FILES=(
  '.githooks/patterns.local'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=AM)

if [[ -z "${STAGED_FILES}" ]]; then
  exit 0
fi

VIOLATIONS=""

while IFS= read -r file; do
  [[ -z "${file}" ]] && continue

  skip=false
  for excl in "${EXCLUDE_FILES[@]}"; do
    if [[ "${file}" == "${excl}" ]]; then
      skip=true
      break
    fi
  done
  [[ "${skip}" == true ]] && continue

  file_diff=$(git diff --cached -U0 --diff-filter=AM -- "${file}")
  hits=$(printf '%s\n' "${file_diff}" \
    | grep -E '^\+' \
    | grep -Ev '^\+\+\+ ' \
    | grep -iE "${JOINED}" || true)

  if [[ -n "${hits}" ]]; then
    VIOLATIONS+="--- ${file} ---"$'\n'
    VIOLATIONS+="${hits}"$'\n'
    VIOLATIONS+=$'\n'
  fi
done <<< "${STAGED_FILES}"

if [[ -n "${VIOLATIONS}" ]]; then
  echo ""
  echo "BLOCKED: staged changes contain sensitive patterns."
  echo "Defined in: ${PATTERN_FILE}"
  echo ""
  printf '%s' "${VIOLATIONS}" | sed 's/^/  /'
  echo ""
  echo "Remove or replace the offending content before committing."
  exit 1
fi

exit 0
