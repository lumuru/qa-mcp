# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Playwright
test-results/
playwright-report/
playwright/.cache/
blob-report/
.playwright-mcp/
results/

# Test artifacts (traces, videos, screenshots, auth state)
*.webm
*.zip
storageState.json
auth.json

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.json

# Project-specific test suites (company property — internal URLs, selectors, fixtures)
# Block everything under projects/ by default, explicitly allow the public demo project.
projects/*
!projects/.gitkeep
!projects/sample-project/
projects/sample-project/**/node_modules/
projects/sample-project/**/test-results/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
*.swp
*.swo

# Pre-commit hook local pattern file (contains real sensitive strings)
.githooks/patterns.local

# Company-property filename markers (docs/artifacts referencing internal systems).
# Content scanning is handled by the pre-commit hook reading patterns from
# .githooks/patterns.local; this section only blocks common filename shapes.
*BSC-*
*SDM-*
