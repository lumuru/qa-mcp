# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Playwright
test-results/
playwright-report/
playwright/.cache/
blob-report/
.playwright-mcp/
results/

# Test artifacts (traces, videos, screenshots, auth state)
*.webm
*.zip
storageState.json
auth.json

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.json

# Project-specific test suites (company property — internal URLs, selectors, fixtures)
# Block everything under projects/ by default, explicitly allow the public demo project.
projects/*
!projects/.gitkeep
!projects/sample-project/
projects/sample-project/**/node_modules/
projects/sample-project/**/test-results/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
*.swp
*.swo

# Company-property filename patterns (docs, artifacts referencing internal systems)
# The pre-commit hook in .githooks/pre-commit additionally scans file CONTENTS
# for internal URLs; .gitignore here only blocks by filename.
*BSC-*
*SDM-*
*bsc-qas*
*sdm-qas*
*REDACTED.example*
